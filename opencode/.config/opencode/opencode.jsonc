{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": [
    "@paflopes/opencode-qwen-auth@latest",
    "opencode-gemini-auth@latest"
  ],
  "lsp": {
    "steel-language-server": {
      "command": ["steel-language-server"],
      "extensions": [".scm"]
    },
    "nu":{
      "command": ["/usr/bin/nu"],
      "extensions":[".nu"]
    }
  }
}
