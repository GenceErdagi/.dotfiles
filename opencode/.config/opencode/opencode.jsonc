{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": [
    "@paflopes/opencode-qwen-auth@latest",
    "opencode-gemini-auth@latest"
  ],
  "lsp": {
    "steel-language-server": {
      "command": [
        "steel-language-server"
      ],
      "extensions": [
        ".scm"
      ]
    },
    "nu": {
      "command": [
        "/usr/bin/nu"
      ],
      "extensions": [
        ".nu"
      ]
    }
  },
  "provider": {
    "foundry": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Foundry",
      "options": {
        "baseURL": "http://127.0.0.1:5273/v1",
        "apiKey": "notneeded"
      },
      "models": {
        "qwen2.5-7b-instruct-qnn-npu:2": {
          "name": "qwen2.5-7b",
          "limit": {
            "context": 20000,
            "output": 4096
          }
        }
      }
    }
  }
}