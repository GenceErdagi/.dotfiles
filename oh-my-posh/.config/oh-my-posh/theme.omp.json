{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "version": 4,
  "console_title_template": "{{ .Folder }}",
  "palette": {
    "grey_light": "#b4b4b4",
    "grey_dark": "#1d1d1d",
    "orange": "#E49A44",
    "brown_dark": "#322119",
    "salmon": "#DF6464",
    "grey_darker": "#111111",
    "red_muted": "#B14242",
    "white_dim": "#e5e5e5",
    "black_light": "#1e1e1e",
    "green": "#68A063",
    "green_dark": "#39513A",
    "yellow": "#FFD43B",
    "blue_cyan": "#00ADD8",
    "grey_medium": "#323232",
    "orange_gold": "#E5A72A",
    "white": "#ffffff",
    "orange_dark": "#D65D0E",
    "purple": "#512BD4",
    "blue_sky": "#0DB7ED",
    "purple_light": "#844FBA",
    "grey_lighter": "#d5d5d5",
    "red": "#C53030"
  },
  "transient_prompt": {
    "background": "transparent",
    "foreground": "p:salmon",
    "template": " \uf0da "
  },
  "blocks": [
    {
      "type": "prompt",
      "alignment": "left",
      "segments": [
        {
          "type": "time",
          "style": "diamond",
          "powerline_symbol": "\ue0c6",
          "background": "p:grey_dark",
          "foreground": "p:orange",
          "template": " {{ .CurrentDate | date \"15:04\" }} "
        },

        {
          "type": "status",
          "style": "powerline",
          "powerline_symbol": "\ue0c6",
          "background": "p:grey_medium",
          "foreground": "p:salmon",
          "template": " {{ if gt .Code 0 }}\uf00d {{ .Code }}{{ else }}\uf00c{{ end }} "
        },

        {
          "type": "os",
          "style": "powerline",
          "powerline_symbol": "\ue0c6",
          "background": "p:green",
          "foreground": "p:white_dim",
          "template": " {{ .Icon }} ",
          "options": {
            "linux": "\uf37d ",
            "macos": "\uf179 ",
            "ubuntu": "\uf31b ",
            "windows": "\ue62a "
          }
        },
        {
          "type": "shell",
          "style": "powerline",
          "powerline_symbol": "\ue0c6",
          "background": "p:grey_medium",
          "foreground": "p:grey_light",
          "template": "  \uebca {{ .Name }} "
        },
        {
          "type": "path",
          "style": "powerline",
          "powerline_symbol": "\ue0c6",
          "background": "p:red_muted",
          "foreground": "p:white_dim",
          "options": {
            "folder_icon": " \uf07b ",
            "folder_separator_icon": " \uf0da ",
            "home_icon": " \ueb06 ",
            "style": "full",
            "max_depth": 2
          },
          "template": " {{ .Path }} "
        },
        {
          "type": "node",
          "style": "powerline",
          "powerline_symbol": "\ue0c6",
          "foreground": "p:black_light",
          "background": "p:green",
          "template": "  \ued44  {{ .Full }} "
        },
        {
          "type": "python",
          "style": "powerline",
          "powerline_symbol": "\ue0c6",
          "foreground": "p:black_light",
          "background": "p:yellow",
          "template": " \ue606 {{ .Full }} "
        },
        {
          "type": "go",
          "style": "powerline",
          "powerline_symbol": "\ue0c6",
          "foreground": "p:black_light",
          "background": "p:blue_cyan",
          "template": "  {{ .Full }} "
        },
        {
          "type": "rust",
          "style": "powerline",
          "powerline_symbol": "\ue0c6",
          "foreground": "p:grey_medium",
          "background": "p:orange_gold",
          "template": "  {{ .Full }} "
        },
        {
          "type": "java",
          "style": "powerline",
          "powerline_symbol": "\ue0c6",
          "foreground": "p:white",
          "background": "p:orange_dark",
          "template": "  {{ .Full }} "
        },
        {
          "type": "dotnet",
          "style": "powerline",
          "powerline_symbol": "\ue0c6",
          "foreground": "p:white",
          "background": "p:purple",
          "template": "  {{ .Full }} "
        },
        {
          "type": "docker",
          "style": "powerline",
          "powerline_symbol": "\ue0c6",
          "foreground": "p:white",
          "background": "p:blue_sky",
          "template": "  "
        },
        {
          "type": "terraform",
          "style": "powerline",
          "powerline_symbol": "\ue0c6",
          "foreground": "p:white",
          "background": "p:purple_light",
          "template": "  "
        }
      ]
    },

    {
      "type": "prompt",
      "alignment": "right",
      "segments": [
        {
          "type": "executiontime",
          "style": "powerline",
          "powerline_symbol": "\ue0c7",
          "leading_diamond": "\ue0c7",
          "invert_powerline": true,
          "background": "p:grey_medium",
          "foreground": "p:grey_lighter",
          "background_templates": ["{{ if gt .Code 0 }}p:red{{ end }}"],
          "options": { "style": "roundrock", "threshold": 500 },
          "template": " {{ .FormattedMs }} "
        },

        {
          "type": "sysinfo",
          "style": "powerline",
          "powerline_symbol": "\ue0c7",
          "invert_powerline": true,
          "background": "p:red_muted",
          "foreground": "p:white_dim",
          "template": " {{ if gt .PhysicalPercentUsed 75.0 }}\ue266 MEM {{ round .PhysicalPercentUsed 2 }}%{{ end }} "
        },

        {
          "type": "git",
          "style": "powerline",
          "powerline_symbol": "\ue0c7",
          "invert_powerline": true,
          "background": "p:green",
          "foreground": "p:black_light",
          "background_templates": [
            "{{ if or (.Working.Changed) (.Staging.Changed) }}p:yellow{{ end }}",
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:red{{ end }}",
            "{{ if gt .Ahead 0 }}p:red{{ end }}",
            "{{ if gt .Behind 0 }}p:red{{ end }}"
          ],
          "foreground_templates": [
            "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:white_dim{{ end }}",
            "{{ if gt .Ahead 0 }}p:white_dim{{ end }}",
            "{{ if gt .Behind 0 }}p:white_dim{{ end }}"
          ],
          "options": {
            "branch_icon": "\ue0a0 ",
            "fetch_status": true,
            "fetch_upstream_icon": false
          },
          "template": " {{ .UpstreamIcon }}{{ .HEAD }}{{ if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \ueb4b {{ .StashCount }}{{ end }} "
        },

        {
          "type": "battery",
          "style": "powerline",
          "powerline_symbol": "\ue0c7",
          "invert_powerline": true,
          "background": "p:green",
          "foreground": "p:black_light",
          "background_templates": [
            "{{ if lt .Percentage 50 }}p:yellow{{ end }}",
            "{{ if lt .Percentage 20 }}p:red{{ end }}"
          ],
          "foreground_templates": [
            "{{ if lt .Percentage 20 }}p:white_dim{{ end }}"
          ],
          "options": {
            "not_charging_icon": "\udb85\udc25 ",
            "discharging_icon": "\uf242 ",
            "charging_icon": "\uf1e6 ",
            "charged_icon": "\uf240 "
          },
          "template": " {{ if not .Error }}{{ .Icon }}{{ .Percentage }}%{{ end }} "
        }
      ]
    },

    {
      "type": "prompt",
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "type": "text",
          "style": "plain",
          "template": "<p:salmon> \uf0da </>"
        }
      ]
    }
  ]
}