layout {
    // ---------------------------------------------------
    // Template with compact-bar
    // ---------------------------------------------------
    default_tab_template {
        children
        pane size=1 borderless=true {
            plugin location="zellij:compact-bar"
        }
    }

    // ---------------------------------------------------
    // Initial IDE Tab (Sidebar Only - No Terminal)
    // ---------------------------------------------------
    tab name="IDE" focus=true {
        pane split_direction="vertical" {
            pane size="15%" command="env" name="File-Explorer" focus=true {
                args "YAZI_IDE_SIDEBAR=1" "nu" "/home/gence/.config/nushell/scripts/yazi-zx.nu"
            }
            pane split_direction="horizontal" {
                pane command="hx" name="Editor"
                pane name="Terminal" size=1
            }
        }
    }

    // ---------------------------------------------------
    // IDE-Specific Tiled Swap Layouts
    // ---------------------------------------------------
    swap_tiled_layout name="IDE_FULL" {
        tab {
            pane split_direction="vertical" {
                pane name="File-Explorer" size="15%"
                pane split_direction="horizontal" {
                    pane { children; }
                    pane name="Terminal" size="25%"
                }
            }
        }
    }

    swap_tiled_layout name="IDE_NO_SIDEBAR" {
        tab {
            pane split_direction="vertical" {
                pane name="File-Explorer" size=1
                pane split_direction="horizontal" {
                    pane { children; }
                    pane name="Terminal" size="25%"
                }
            }
        }
    }

    swap_tiled_layout name="IDE_NO_TERMINAL" {
        tab {
            pane split_direction="vertical" {
                pane name="File-Explorer" size="15%"
                pane split_direction="horizontal" {
                    pane { children; }
                    pane name="Terminal" size=1
                }
            }
        }
    }

    swap_tiled_layout name="IDE_ZEN" {
        tab {
            pane split_direction="vertical" {
                pane name="File-Explorer" size=1
                pane split_direction="horizontal" {
                    pane { children; }
                    pane name="Terminal" size=1
                }
            }
        }
    }
}
